# ─────────────────────────────────────────────────────────────────────────────
# TridentWear — Environment Variables Template
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | production
HOST=0.0.0.0
PORT=8000

# ── Security — JWT & Session ──────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
TRIDENT_JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
TRIDENT_SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
TRIDENT_JWT_EXPIRATION_DAYS=7
TRIDENT_SESSION_MAX_AGE_SECONDS=604800

# ── CORS ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Comma-separated list of exact allowed origins.
# Do NOT use "*" — credentials (cookies/JWT) are enabled.
# Example: https://tridentwear.in,https://www.tridentwear.in
ALLOWED_ORIGINS=https://tridentwear.in,https://www.tridentwear.in

# ── Admin Credentials ─────────────────────────────────────────────────────────
# REQUIRED in production. Set these before first deployment.
# Option A: Provide a bcrypt hash (preferred):
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt()).decode())"
# Option B: Provide a raw password (will be used at first login only, less secure):
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH
# ADMIN_PASSWORD=YourRawPasswordHere   # Only if not using ADMIN_PASSWORD_HASH

# ── Razorpay ──────────────────────────────────────────────────────────────────
# REQUIRED for online payments. Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys during testing, rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_live_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME
TRIDENT_ENABLE_TEST_ORDERS=false

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Required for email OTP and order confirmation emails.
# Gmail: use App Password if 2FA is enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── OTP Settings ──────────────────────────────────────────────────────────────
TRIDENT_OTP_PROVIDER=dev         # dev | twilio | msg91 | fast2sms
TRIDENT_OTP_EXPIRY_MINUTES=5
TRIDENT_OTP_RESEND_SECONDS=45
TRIDENT_OTP_MAX_ATTEMPTS=5
TRIDENT_OTP_MAX_SENDS_PER_HOUR=5
TRIDENT_OTP_BLOCK_MINUTES=15

# ── Database ──────────────────────────────────────────────────────────────────
# json = file-based (default, requires persistent disk on Render)
# postgres = PostgreSQL via SQLAlchemy (not yet wired to all services)
DB_MODE=json
# PG_DSN=postgresql://user:password@host:5432/tridentwear

# ── Optional ──────────────────────────────────────────────────────────────────
# Leave empty when frontend and backend are on the same origin.
TRIDENT_API_ROOT=
